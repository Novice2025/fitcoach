# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

 # dependencies
 /node_modules
 /.pnp
 .pnp.*
 .yarn/*
 !.yarn/patches
 !.yarn/plugins
 !.yarn/releases
 !.yarn/versions

 # testing
 /coverage

 # next.js
 /.next/
 /out/

 # production
 /build

 # misc
 .DS_Store
 *.pem

 # debug
 npm-debug.log*
 yarn-debug.log*
 yarn-error.log*
 .pnpm-debug.log*

 # env files (can opt-in for committing if needed)
 .env*
 !.env.example

 # vercel
 .vercel

 # typescript
 *.tsbuildinfo
 next-env.d.ts

 # ---------------------------------------------------
 # ADIÇÕES PARA PROJETO PYTHON/FLASK E OUTROS GERAIS
 # ---------------------------------------------------

 # Python
 __pycache__/
 *.pyc
 *.pyo
 *.pyd
 .Python
 env/
 venv/ # Ignora a pasta do ambiente virtual Python
 .venv/
 pip-log.txt
 pip-delete-this-directory.txt
 .tox/
 .coverage
 .coverage.*
 .hypothesis/
 .pytest_cache/
 celerybeat-schedule.*
 .dmypy.json
 .mypy_cache/
 .pyre/
 .ipynb_checkpoints
 .spyderproject
 .spyproject
 .vscode/ # Ignora configurações específicas do VS Code (opcional, mas recomendado)
 .history/ # Ignora histórico de arquivos do VS Code (opcional)

 # Flask
 instance/ # Ignora a pasta 'instance' do Flask
 fitcoach.db # Ignora o arquivo do banco de dados SQLite

 # Logs
 *.log

 # OS generated files
 .Trashes
 Thumbs.db
